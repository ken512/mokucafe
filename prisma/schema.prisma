generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Supabase Auth と紐づくユーザープロフィール
model User {
  id             Int           @id @default(autoincrement())
  supabaseUserId String        @unique // Supabase Auth の UUID
  name           String
  avatarUrl      String?
  bio            String?
  xUrl           String?       // X（旧Twitter）のプロフィールURL
  instagramUrl   String?       // Instagram のプロフィールURL
  threadsUrl     String?       // Threads のプロフィールURL
  githubUrl      String?       // GitHub のプロフィールURL
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  posts             Post[]
  applications      Application[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

// カフェでの作業募集投稿
model Post {
  id           Int           @id @default(autoincrement())
  userId       Int
  cafeName     String        // カフェ名
  cafeAddress  String?       // カフェの住所
  cafePlaceId  String?       // Google Places の placeId（地図の正確なピン留めに使用）
  date         DateTime      // 作業開始日時
  endDate      DateTime?     // 作業終了日時（nullの場合は終了時間なし）
  capacity     Int           // 募集人数
  description  String        // 募集内容・説明
  tags         String[]      // 雰囲気タグ（例：["静かに作業", "会話OK"]）
  mediaUrls    String[]      // カフェ写真・動画のURL（最大3件：画像2枚＋動画1本）
  status       PostStatus    @default(OPEN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications  Application[]
  notifications Notification[]

  // 一覧取得（status + 降順）・テキスト検索（cafeName）用インデックス
  @@index([status, createdAt(sort: Desc)])
  @@index([cafeName])
  @@map("posts")
}

// 募集への参加申請
model Application {
  id        Int               @id @default(autoincrement())
  postId    Int
  userId    Int
  message   String?           // 申請メッセージ（任意）
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  post      Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 同じユーザーが同じ募集に二重申請できないようにする
  @@unique([postId, userId])
  @@map("applications")
}

// アプリ内通知
model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  body      String
  postId    Int?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// Web Push 購読情報（端末ごとに保持）
model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

enum NotificationType {
  NEW_APPLICATION      // オーナー: 新規申請
  APPLICATION_APPROVED // 申請者: 承認
  APPLICATION_REJECTED // 申請者: 却下
  ATTENDANCE_CONFIRMED // オーナー: 参加確定
  SYSTEM               // システム通知（ウェルカム・案内など）
}

enum PostStatus {
  OPEN    // 募集中
  CLOSED  // 締め切り
  DONE    // 終了
}

enum ApplicationStatus {
  PENDING    // 申請中
  APPROVED   // 承認済み（参加未確定）
  ATTENDING  // 参加確定（ユーザー自身が確認）
  REJECTED   // 却下
}
